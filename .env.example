# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username

# Owner & Admin
OWNER_ID=your_telegram_user_id
OWNER_USERNAME=your_username

# API Keys
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4-turbo

# Database
DATABASE_URL=mongodb://localhost:27017/tila-bot
USE_LOCAL_DB=true

# Server
PORT=3000
NODE_ENV=development

# Feature Flags
ENABLE_AI=true
ENABLE_GROUP_MANAGEMENT=true
ENABLE_FUN_COMMANDS=true
ENABLE_ECONOMY=false

# Anti-Spam Settings
FLOOD_THRESHOLD=5
FLOOD_TIMEOUT=10
BAN_DURATION=3600

# Support & Links
SUPPORT_GROUP=https://t.me/simonwolftech
BOT_DEVELOPER=@TILATECHBOT
GITHUB_REPO=https://github.com/princetechbusinessassociations-byte/evil-tyla-tech-bot